<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:vm.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ui.Views.MainWindow"
        x:DataType="vm:MainWindowVm"
        Icon="/Assets/avalonia-logo.ico"
        Title="dashb">

    <Window.Styles>
        <Style Selector="Button.h1">
            <Setter Property="Height" Value="38" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*"
          ColumnDefinitions="*,Auto,*">

        <Grid Grid.Row="0"
              Grid.Column="0"
              ColumnDefinitions="Auto,*">
            <Menu Grid.Column="0">
                <MenuItem Header="File">
                    <MenuItem Header="Open" Command="{Binding OpenCommand}" />
                    <MenuItem Header="Save" Command="{Binding SaveCommand}" />
                </MenuItem>
            </Menu>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <TextBlock Text="Ntrip servers"
                           FontWeight="Bold"
                           Padding="10 5 10 0" />
                <Button Command="{Binding CreateServerCommand}"
                        Content="Create server" />
            </StackPanel>
        </Grid>

        <TreeView ItemsSource="{Binding Servers}"
                  Grid.Row="1"
                  Grid.Column="0"
                  SelectedItem="{Binding Path=SelectedServer,
                                         Mode=TwoWay}">
            <TreeView.DataTemplates>
                <TreeDataTemplate DataType="vm:NtripServerVm"
                                  ItemsSource="{Binding Clients}">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                DragDrop.AllowDrop="True"
                                DragDrop.DragOver="Servers_OnDragOver"
                                DragDrop.Drop="Servers_OnDrop"
                                Background="Transparent">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="16"
                                   Padding="0 0 8 0"
                                   VerticalAlignment="Center" />
                        <Button Command="{Binding EditCmd}"
                                CommandParameter="{Binding .}"
                                FontSize="20"
                                Classes="h1"
                                Content="&#x1F589;" />
                        <Button Command="{Binding RemoveCommand}"
                                FontSize="20"
                                CommandParameter="{Binding Path=((vm:MainWindowVm)DataContext).Servers,
                                                   RelativeSource={RelativeSource AncestorType={x:Type TreeView},
                                                                                  Mode=FindAncestor}}"
                                Classes="h1"
                                Content="&#9003;" />
                    </StackPanel>
                </TreeDataTemplate>
                <DataTemplate DataType="vm:NtripClientVm">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                    FontSize="16"
                                    Padding="0 0 8 0"
                                    VerticalAlignment="Center" />
                        <Button Command="{Binding UnassignCommand}"
                                CommandParameter="{Binding Path=Parent?.DataContext,
                                                   RelativeSource={RelativeSource Mode=FindAncestor,
                                                                                  AncestorType={x:Type TreeViewItem},
                                                                                  AncestorLevel=1}}"
                                FontSize="20"
                                Classes="h1"
                                Content="&#9003;" />
                    </StackPanel>
                </DataTemplate>
            </TreeView.DataTemplates>
        </TreeView>

        <GridSplitter Grid.Row="0"
                      Grid.Column="1"
                      Grid.RowSpan="3"
                      Background="Gray" />

        <Grid Grid.Row="0"
              Grid.Column="2"
              Grid.RowSpan="3"
              RowDefinitions="Auto,*">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <TextBlock Text="Ntrip clients"
                           FontWeight="Bold"
                           Padding="10 5 10 0" />
                <Button Command="{Binding CreateClientCommand}"
                        Content="Create client" />
            </StackPanel>
            <ListBox ItemsSource="{Binding Clients}"
                     Grid.Row="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    PointerPressed="Clients_OnPointerPressed"
                                    PointerMoved="Clients_OnPointerMoved"
                                    Background="Transparent">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="16"
                                       Padding="0 0 8 0"
                                       VerticalAlignment="Center" />
                            <Button Command="{Binding AssignCommand}"
                                    CommandParameter="{Binding Path=((vm:MainWindowVm)DataContext).SelectedServer,
                                                       RelativeSource={RelativeSource AncestorType={x:Type ListBox},
                                                                                      Mode=FindAncestor}}"
                                    FontSize="20"
                                    Classes="h1"
                                    Content="&#x1F517;" />
                            <Button Command="{Binding EditCmd}"
                                    CommandParameter="{Binding .}"
                                    FontSize="20"
                                    Classes="h1"
                                    Content="&#x1F589;" />
                            <Button Command="{Binding RemoveCommand}"
                                    FontSize="20"
                                    Classes="h1"
                                    Content="&#9003;">
                                <Button.CommandParameter>
                                    <MultiBinding>
                                        <Binding Path="((vm:MainWindowVm)DataContext)?.Servers"
                                                 RelativeSource="{RelativeSource AncestorType={x:Type ListBox},
                                                                                 Mode=FindAncestor}" />
                                        <Binding Path="((vm:MainWindowVm)DataContext)?.Clients"
                                                 RelativeSource="{RelativeSource AncestorType={x:Type ListBox},
                                                                                 Mode=FindAncestor}" />
                                    </MultiBinding>
                                </Button.CommandParameter>
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Grid>

</Window>
